# Template for per-team env file. Generated automatically by scripts/deploy-team.sh.
# Do NOT edit manually; copy as .env.<team-slug> and customize if needed.

# Team identity
TEAM_SLUG=alpha

# Ports (offset by team number N: 8000+N, 8400+N, 5430+N)
API_PORT=8001
STUDIO_PORT=8401
POSTGRES_PORT=5431

# Database
POSTGRES_DB=hackathon
POSTGRES_PASSWORD=change-me-random-32-bytes

# PostgREST authenticator role (NOT handed out; internal only)
AUTHENTICATOR_PASSWORD=change-me-random-32-bytes

# Team-specific DB user (handed out for direct psql access)
TEAM_DB_USER=team_writer_alpha
TEAM_DB_PASSWORD=change-me-random-32-bytes

# JWT (32-byte random string; derives ANON_KEY and SERVICE_ROLE_KEY)
JWT_SECRET=change-me-at-least-32-characters-long

# Derived JWTs (handed out to team; generated by deploy-team.sh)
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
